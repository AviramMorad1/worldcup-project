# Reddit data is collected via public RSS feeds — no API credentials required.
COLLECTION_INTERVAL_HOURS=168
PREPROCESS_INTERVAL_MINUTES=60

# ── Trainer / prediction settings ──────────────────────────────────────────

# Recency weighting for training samples.
# Recent tournaments receive higher weight; older ones are down-weighted.
# Set to false to use uniform weights (not recommended with full historical data).
RECENCY_WEIGHTING_ENABLED=true

# Exponential decay rate: weight = exp(-decay * (2026 - match_year))
# Higher value → older matches weighted less. Default 0.08 gives 2018≈0.85, 2006≈0.45.
RECENCY_DECAY_RATE=0.08

# Minimum weight floor (prevents very old matches from being ignored entirely).
MIN_RECENCY_WEIGHT=0.35

# ── Current FIFA rankings ──────────────────────────────────────────────────
# Place a CSV file with columns (team, rank, points) at this path for best predictions.
# If absent, predictions fall back to historical rankings (less accurate for 2026).
CURRENT_RANKINGS_CSV=datasets/current_rankings.csv

# ── Squad / player strength features (optional) ────────────────────────────
# Enable/disable squad strength adjustment for 2026 predictions.
# Requires players_data_2025_2026.csv in datasets/.
SQUAD_FEATURES_ENABLED=true

# Conservative blending weight for squad adjustment (0.0 = disabled, 1.0 = full).
SQUAD_ADJUSTMENT_ENABLED=true
SQUAD_ADJUSTMENT_WEIGHT=0.20

# Maximum probability shift from squad adjustment (default: ±2% combined).
MAX_SQUAD_PROBA_ADJUSTMENT=0.08

# football-data.org API for national team squad lists (optional, free tier limited).
# If token is empty or API fails, falls back to manual squad CSV / player stats.
FOOTBALL_DATA_API_TOKEN=
SQUAD_API_ENABLED=true
SQUAD_SOURCE=football-data
SQUAD_SEASON=2026

# ── Telegram (optional) ────────────────────────────────────────────────────
# Required only if you want Telegram channel data collection.
# TELEGRAM_API_ID=your_api_id
# TELEGRAM_API_HASH=your_api_hash
# TELEGRAM_CHANNELS=FIFAWorldCup_FWC,fifaworldcup
# TELEGRAM_LIMIT_PER_CHANNEL=50
# TELEGRAM_COLLECT_COMMENTS=false
# TELEGRAM_COMMENT_POST_LIMIT_PER_CHANNEL=10
# TELEGRAM_COMMENT_LIMIT_PER_POST=20
