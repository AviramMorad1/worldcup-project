# Reddit data is collected via public RSS feeds — no API credentials required.
COLLECTION_INTERVAL_HOURS=168
PREPROCESS_INTERVAL_MINUTES=60

# ---------------------------------------------------------------------------
# Telegram collection (optional)
# ---------------------------------------------------------------------------
# Leave these commented out to skip Telegram collection entirely.
# To enable, fill in your Telegram API credentials from https://my.telegram.org
# and list the public channel usernames you want to collect from.
#
# First-run authentication:
#   docker compose run --rm collector python /app/telegram_auth.py
#
# After the session file is created subsequent runs are non-interactive.
#
# TELEGRAM_API_ID=123456
# TELEGRAM_API_HASH=your_api_hash_here
# TELEGRAM_SESSION_NAME=worldcup_sentiment_telegram
# TELEGRAM_CHANNELS=Argentina_fan
# TELEGRAM_LIMIT_PER_CHANNEL=50
#
# Comment collection — disabled by default.
# When enabled, replies to the most recent posts are collected and processed
# through the same VADER/TextBlob sentiment pipeline as posts.
# Key feature: comments inherit the national team context from their parent post.
#   Example: if a Telegram post is about Ghana's World Cup squad, comments like
#   "Ooh no" or "Dem all hurt" will still be tagged as Ghana sentiment.
# Only comments accessible to the logged-in account are collected.
# Private channels/discussion groups are not bypassed.
# TELEGRAM_COLLECT_COMMENTS=false
# TELEGRAM_COMMENT_POST_LIMIT_PER_CHANNEL=5
# TELEGRAM_COMMENT_LIMIT_PER_POST=30
