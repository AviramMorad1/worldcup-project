# Reddit data is collected via public RSS feeds
COLLECTION_INTERVAL_HOURS=6
PREPROCESS_INTERVAL_MINUTES=60
RECENCY_WEIGHTING_ENABLED=true
RECENCY_DECAY_RATE=0.08
MIN_RECENCY_WEIGHT=0.35
CURRENT_RANKINGS_CSV=datasets/current_rankings.csv
SQUAD_FEATURES_ENABLED=true
SQUAD_ADJUSTMENT_ENABLED=true
SQUAD_ADJUSTMENT_WEIGHT=0.20
MAX_SQUAD_PROBA_ADJUSTMENT=0.08
FOOTBALL_DATA_API_TOKEN= ""
SQUAD_API_ENABLED=true
SQUAD_SOURCE=football-data
SQUAD_SEASON=2026

